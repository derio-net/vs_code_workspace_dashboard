# Docker Compose Configuration Example
# Copy this file to .env and update the values as needed

# Port to expose the application on (default: 3010)
# Used by the server and Tauri desktop app
DASHBOARD_PORT=3010

# Legacy port variable (still supported for backward compatibility)
PORT=3010

# Port for the React development server during Tauri development (default: 3020)
# Only used during development, not in production
# Change this if port 3020 is already in use
DASHBOARD_DEV_PORT=3020

# Path to VS Code workspaces directory on the HOST machine
# This directory will be mounted as read-only in the container at /workspaces
# The application inside the container will always use /workspaces
# Examples:
#   /Users/username/Library/Application Support/Code/User/workspaceStorage
#   /home/username/.config/Code/User/workspaceStorage
#   /data/workspaces
WORKSPACES_MOUNT_POINT=/Users/username/Library/Application Support/Code/User/workspaceStorage
